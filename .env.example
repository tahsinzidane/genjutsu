# supabase configuration
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"

# (Optional) Google OAuth Configuration
# Note: Google OAuth is configured directly in the Supabase Dashboard under Authentication -> Providers.
# You usually DO NOT need to add Google Client ID / Secret in your `.env` file for the client to work,
# as `supabase.auth.signInWithOAuth({ provider: 'google' })` handles it automatically.
# However, if your backend requires it for specific edge cases, add them here:
# VITE_SUPABASE_GOOGLE_CLIENT_ID="your_google_client_id"
# VITE_SUPABASE_GOOGLE_CLIENT_SECRET="your_google_client_secret"



# admin configuration (you wont get acces by just adding email here, this just show admin button in you prfile but you can never access the admin panel if you're not added in admin list in supabase by author _ Ovi ren, if you don't have access, just keep it as it is, no need to change or just remove it)
VITE_ADMIN_EMAILS="email1@example.com,email2@example.com"
